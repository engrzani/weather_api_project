{
    "builds": [
        {
            "src": "api/*.py",
            "use": "@vercel/python"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        { "src": "/api/search", "dest": "/api/search.py" },
        { "src": "/api/weather", "dest": "/api/weather.py" },
        { "src": "/api/pollution", "dest": "/api/pollution.py" },
        { "src": "/(.*)", "dest": "/public/$1" }
    ]
}
